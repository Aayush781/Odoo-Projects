<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Hide all root menus from non-admin users, keep only Maintenance visible -->

    <!-- Hide Discuss -->
    <record id="mail.menu_root_discuss" model="ir.ui.menu">
        <field name="group_ids" eval="[(6, 0, [ref('base.group_system')])]"/>
    </record>

    <!-- Hide Apps/App Store -->
    <record id="base.menu_management" model="ir.ui.menu">
        <field name="group_ids" eval="[(6, 0, [ref('base.group_system')])]"/>
    </record>

    <!-- Hide Settings -->
    <record id="base.menu_administration" model="ir.ui.menu">
        <field name="group_ids" eval="[(6, 0, [ref('base.group_system')])]"/>
    </record>

    <!-- Hide Contacts -->
    <record id="contacts.menu_contacts" model="ir.ui.menu">
        <field name="group_ids" eval="[(6, 0, [ref('base.group_system')])]"/>
    </record>

    <!-- Hide Inventory/Stock (menu hidden but functionality preserved) -->
    <record id="stock.menu_stock_root" model="ir.ui.menu">
        <field name="group_ids" eval="[(6, 0, [ref('base.group_system')])]"/>
    </record>

</odoo>
