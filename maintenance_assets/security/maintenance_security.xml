<odoo>
    <data noupdate="0">
        <!-- Global rule: users only see assets belonging to their team -->
        <record id="rule_maintenance_equipment_read_all" model="ir.rule">
            <field name="name">Equipment: Team-Based Read Access</field>
            <field name="model_id" ref="maintenance.model_maintenance_equipment"/>
            <field name="global" eval="True"/>
            <field name="domain_force">['|', '|', '|',
                (user.has_group('base.group_system'), '=', True),
                (user.has_group('maintenance.group_equipment_manager'), '=', True),
                ('maintenance_team_id', '=', False),
                ('maintenance_team_id.member_ids', 'in', [user.id])
            ]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>
    </data>
</odoo>
